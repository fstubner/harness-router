# harness-router-mcp — environment variables
#
# Copy this file to .env and fill in values for the services you use.
# Reference these in config.yaml via ${ENV_VAR_NAME} interpolation.
#
# Note: when using Claude Desktop or Cursor, set these in the "env" block
# of claude_desktop_config.json instead of a .env file.

# ── Server config ────────────────────────────────────────────────────────────

# Path to your config.yaml. Defaults to config.yaml in the project root,
# overridable per-invocation with --config.
# HARNESS_ROUTER_CONFIG=/path/to/config.yaml

# ── API keys ─────────────────────────────────────────────────────────────────
#
# Claude Code and Codex authenticate via OAuth (claude auth login / codex auth
# login) and do not require API keys here. Gemini CLI can use either OAuth or
# an API key.

# Gemini CLI / Google AI Studio
# GEMINI_API_KEY=your-gemini-api-key-here
# GOOGLE_API_KEY=your-google-api-key-here   # alternative env var for Gemini

# Anthropic API key — only needed if bypassing Claude Code OAuth
# ANTHROPIC_API_KEY=your-anthropic-api-key-here

# OpenAI API key — only needed if bypassing Codex OAuth
# OPENAI_API_KEY=your-openai-api-key-here

# OpenRouter — for openai_compatible services pointing at openrouter.ai
# OPENROUTER_API_KEY=your-openrouter-api-key-here
